/* POI 卡片组件样式 */
.poi-card {
  display: flex;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.poi-card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.poi-image {
  width: 100%;
  height: 100%;
}

.poi-type-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 22rpx;
  text-align: center;
  padding: 4rpx 0;
}

.poi-card-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.poi-card-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.poi-card-rating {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating-stars {
  font-size: 24rpx;
  color: #faad14;
}

.rating-price {
  font-size: 24rpx;
  color: #f5222d;
}

.poi-card-address {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.address-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.address-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.poi-card-distance {
  margin-top: 8rpx;
}

.distance-text {
  font-size: 24rpx;
  color: #1890ff;
}

.poi-card-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 20rpx;
}

.action-btn {
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  margin: 0;
}

.navigate-btn {
  background-color: #52c41a;
}