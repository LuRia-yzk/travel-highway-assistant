/* 首页样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 测试区域 */
.test-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  text-align: center;
  color: #ffffff;
}

.test-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.test-hint {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 30rpx;
}

.test-status {
  background-color: rgba(255, 255, 255, 0.2);
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 地图区域 */
.map-section {
  height: 45vh;
  width: 100%;
  position: relative;
}

.road-map {
  width: 100%;
  height: 100%;
}

.location-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

.location-btn image {
  width: 40rpx;
  height: 40rpx;
}

.location-icon-text {
  font-size: 40rpx;
  line-height: 1;
}

/* 位置信息卡片 */
.location-card {
  margin: -40rpx 20rpx 20rpx;
  position: relative;
  z-index: 5;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-refresh {
  font-size: 28rpx;
}

.address-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* 推荐路口区域 */
.recommend-section {
  flex: 1;
  overflow-y: auto;
  padding: 0 20rpx 20rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-top: 10rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999999;
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999999;
}

/* 错误状态 */
.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  background-color: #fffbe6;
  border-radius: 12rpx;
  border: 1rpx solid #ffe58f;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #faad14;
  margin-bottom: 30rpx;
}

.retry-btn {
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* 路口列表 */
.node-list {
  display: flex;
  flex-direction: column;
}

.node-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.node-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.node-index {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.node-info {
  flex: 1;
  min-width: 0;
}

.node-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.node-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.node-highway {
  font-size: 24rpx;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 16rpx;
}

.node-details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #666666;
}

.node-facilities {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.facility-tag {
  font-size: 22rpx;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  border: 1rpx solid #b7eb8f;
}

.node-description {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.node-arrow {
  font-size: 40rpx;
  color: #d9d9d9;
  margin-left: 16rpx;
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.refresh-btn-large {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 60rpx;
  font-size: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.refresh-btn-large:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 首页 - 地图导航页 */
.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

/* 全屏地图 */
.map-container {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.road-map {
  width: 100%;
  height: 100%;
}

.location-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 80rpx;
  height: 80rpx;
  background-color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 10;
}

.location-icon-text {
  font-size: 40rpx;
  line-height: 1;
}

/* 推荐路口悬浮层 */
.recommend-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  z-index: 5;
  max-height: 50vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.overlay-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.overlay-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.overlay-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 刷新按钮 */
.refresh-btn-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.refresh-icon {
  font-size: 28rpx;
}

.refresh-text {
  font-size: 24rpx;
  font-weight: 500;
}

.refresh-btn-header:active {
  opacity: 0.8;
  transform: scale(0.95);
}

/* 路口列表 */
.node-scroll {
  flex: 1;
  overflow-y: auto;
}

.node-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 20rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.node-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.node-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.node-name-blue {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.node-highway {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.node-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.node-distance {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  font-weight: 500;
}

.node-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

/* 错误提示 */
.error-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 26rpx;
  color: #ff6b6b;
  margin-bottom: 20rpx;
}

.retry-btn {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 12rpx 40rpx;
  font-size: 26rpx;
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}
