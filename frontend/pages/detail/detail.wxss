/* 详情页 - 四个服务栏目样式 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  flex: 1;
  text-align: center;
}

.placeholder {
  width: 60rpx;
}

/* 四个导航栏目 */
.tab-nav {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 3rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 24rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #667eea;
  font-weight: bold;
}

/* 内容滚动区域 */
.content-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
}

/* 栏目标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.title-count {
  font-size: 24rpx;
  color: #999;
}

/* POI 卡片列表 */
.poi-list {
  display: flex;
  flex-direction: column;
}

.poi-card {
  display: flex;
  background: #fff;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.poi-image {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.poi-img {
  width: 100%;
  height: 100%;
}

.poi-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.poi-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.poi-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.poi-rating {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.stars {
  color: #ff9500;
  font-size: 24rpx;
}

.price {
  color: #ff6b6b;
  font-size: 26rpx;
  font-weight: bold;
}

.poi-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.distance,
.address,
.cuisine,
.duration {
  font-size: 22rpx;
  color: #666;
}

.poi-features {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.feature-tag {
  font-size: 20rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 评论输入框 */
.comment-input-box {
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  margin-bottom: 16rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  width: 100%;
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
}

.comment-item {
  display: flex;
  background: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.comment-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.username {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.comment-images {
  display: flex;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.comment-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.comment-actions {
  display: flex;
  gap: 30rpx;
  margin-top: 12rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 22rpx;
}

.action-icon {
  font-size: 28rpx;
}

.action-text {
  color: #999;
}
/* 详情页样式 */
.container {
  padding-bottom: 40rpx;
  background-color: #f5f5f5;
}

/* 地图预览 */
.map-preview {
  height: 300rpx;
  width: 100%;
}

.poi-map {
  width: 100%;
  height: 100%;
}

/* 路口信息卡片 */
.node-info-card {
  margin: -40rpx 20rpx 20rpx;
  position: relative;
  z-index: 5;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

.node-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.node-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 24rpx;
}

.node-meta {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 26rpx;
  opacity: 0.9;
}

.node-description {
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.facilities-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.facility-item {
  font-size: 24rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* POI 统计 */
.poi-summary {
  margin: 0 20rpx 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 8rpx;
}

.stat-value.hotel {
  color: #722ed1;
}

.stat-value.restaurant {
  color: #fa8c16;
}

.stat-value.attraction {
  color: #52c41a;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* POI 分类标签 */
.poi-tabs {
  display: flex;
  background-color: #ffffff;
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
}

.tab-item.active {
  color: #1890ff;
  background-color: #e6f7ff;
  border-bottom-color: #1890ff;
  font-weight: bold;
}

/* POI 列表区域 */
.poi-section {
  padding: 0 20rpx;
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999999;
}

/* POI 列表 */
.poi-list {
  display: flex;
  flex-direction: column;
}

.poi-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.poi-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.poi-img {
  width: 100%;
  height: 100%;
}

.poi-type-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 22rpx;
  text-align: center;
  padding: 4rpx 0;
}

.poi-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.poi-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.poi-rating {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.rating-stars {
  font-size: 24rpx;
  color: #faad14;
}

.rating-price {
  font-size: 24rpx;
  color: #f5222d;
}

.poi-address {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.address-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.address-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.poi-distance {
  margin-top: 8rpx;
}

.distance-text {
  font-size: 24rpx;
  color: #1890ff;
}

.poi-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 20rpx;
}

.action-btn {
  background-color: #1890ff;
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  margin: 0;
}

.navigate-btn {
  background-color: #52c41a;
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}