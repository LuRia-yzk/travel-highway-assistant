# 生产环境配置示例
# 复制此文件为 .env 并修改相应配置

# 服务器端口
PORT=3000

# 高德地图 API 配置（生产环境）
AMAP_WEB_KEY=你的生产环境 Web 服务 Key
AMAP_WEB_JS_KEY=你的生产环境 Web 端 Key
AMAP_SECURITY_CODE=你的生产环境安全密钥

# 数据库文件路径
DATABASE_PATH=./database/roadNodes.json
POI_DATABASE_PATH=./database/pois.json

# 推荐路口配置
RECOMMEND_MIN_COUNT=2
RECOMMEND_MAX_COUNT=4
RECOMMEND_DEFAULT_RADIUS=5000

# POI 搜索配置
POI_RADIUS=3000
POI_PAGE_SIZE=10

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs